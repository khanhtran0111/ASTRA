    "typecheck": "pnpm generate-routes && tsc -b --noEmit"
  },
  "dependencies": {
    "@ai-sdk/react": "^3.0.187",
    "@assistant-ui/react": "^0.14.5",
    "@assistant-ui/react-ai-sdk": "^1.3.26",
    "@mastra/ai-sdk": "^1.4.2",
    "@seta/shared-ui": "workspace:^",
    "@tailwindcss/vite": "^4.3.0",
    "@tanstack/react-router": "^1.170.4",
    "@tanstack/react-table": "^8.21.3",
    "@tanstack/router-plugin": "^1.168.6",
    "ai": "^6.0.185",
    "better-auth": "^1.6.11",
    "lucide-react": "^1.16.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "tailwindcss": "^4.3.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
