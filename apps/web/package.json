{
  "name": "@seta/web",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "generate-routes": "tsr generate",
    "build": "pnpm generate-routes && tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "NODE_OPTIONS='--no-experimental-webstorage' vitest run",
