{
  "name": "@seta/server",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "description": "Seta API server — Hono HTTP entry point, dispatcher, and graphile-worker host. Composes every domain module.",
  "scripts": {
    "dev": "tsx watch --env-file=../../.env src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@microsoft/microsoft-graph-client": "^3.0.7",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/auto-instrumentations-node": "^0.76.0",
    "@opentelemetry/exporter-prometheus": "^0.218.0",
    "@opentelemetry/sdk-node": "^0.218.0",
    "@seta/agent": "workspace:^",
    "@seta/agent-sdk": "workspace:^",
    "@seta/core": "workspace:^",
    "@seta/identity": "workspace:^",
    "@seta/integrations": "workspace:^",
    "@seta/knowledge": "workspace:^",
    "@seta/notifications": "workspace:^",
    "@seta/planner": "workspace:^",
    "@seta/shared-crypto": "workspace:^",
    "@seta/shared-db": "workspace:^",
    "@seta/shared-mailer": "workspace:^",
    "@seta/shared-types": "workspace:^",
    "@seta/staffing": "workspace:^",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.23",
    "pino": "^10.3.1",
    "tsx": "^4.22.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@hono/node-server": "^2.0.4",
    "@seta/shared-config": "workspace:^",
    "@seta/shared-testing": "workspace:^",
    "@types/node": "^25.9.1",
    "@types/pg": "^8.20.0",
    "pg": "^8.21.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7"
  }
}
