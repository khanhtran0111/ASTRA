{
  "name": "@seta/shared-crypto",
  "version": "0.0.1",
  "private": true,
  "description": "Envelope encryption helpers — AWS KMS-backed data-key wrapping for credentials at rest, with a local dev key fallback.",
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./testing": "./src/testing/index.ts"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "crypto:gen-local-key": "node --import=tsx scripts/gen-local-key.ts"
  },
  "dependencies": {
    "@aws-sdk/client-kms": "^3.1054.0",
    "pino": "^10.3.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@seta/shared-config": "workspace:^",
    "@types/node": "^25.9.1",
    "aws-sdk-client-mock": "^4.1.0",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7"
  }
}
