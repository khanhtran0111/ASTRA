exports[`template snapshots > password-reset html 1`] = `"<!DOCTYPE html PUBLIC "-//W3C//DTD XHTML 1.0 Transitional//EN" "http://www.w3.org/TR/xhtml1/DTD/xhtml1-transitional.dtd"><html dir="ltr" lang="en"><head><meta content="text/html; charset=UTF-8" http-equiv="Content-Type"/><meta name="x-apple-disable-message-reformatting"/></head><body style="background:#f6f7f9"><!--$--><!--html--><!--head--><!--body--><table border="0" width="100%" cellPadding="0" cellSpacing="0" role="presentation" align="center"><tbody><tr><td style="background:#f6f7f9;font-family:system-ui, sans-serif"><table align="center" width="100%" border="0" cellPadding="0" cellSpacing="0" role="presentation" style="max-width:480px;padding:24px;background:#ffffff"><tbody><tr style="width:100%"><td><h1 style="font-size:20px;margin-bottom:12px">Reset your password</h1><p style="font-size:14px;line-height:24px;margin-top:16px;margin-bottom:16px">Hi <!-- -->Alex Lee<!-- -->, click the button below to reset your password.</p><a href="https://app.seta.example/reset?token=preview" style="line-height:100%;text-decoration:none;display:inline-block;max-width:100%;mso-padding-alt:0px;background:#0047FF;color:#ffffff;padding:10px 16px;border-radius:6px;padding-top:10px;padding-right:16px;padding-bottom:10px;padding-left:16px" target="_blank"><span><!--[if mso]><i style="mso-font-width:400%;mso-text-raise:15" hidden>&#8202;&#8202;</i><![endif]--></span><span style="max-width:100%;display:inline-block;line-height:120%;mso-padding-alt:0px;mso-text-raise:7.5px">Reset password</span><span><!--[if mso]><i style="mso-font-width:400%" hidden>&#8202;&#8202;&#8203;</i><![endif]--></span></a><p style="font-size:12px;line-height:24px;color:#65676b;margin-top:16px;margin-bottom:16px">Link expires <!-- -->2026-05-20 14:00 UTC<!-- -->. Requested from IP <!-- -->192.0.2.10<!-- -->. If you didn&#x27;t request this, you can ignore this email.</p></td></tr></tbody></table></td></tr></tbody></table><!--/$--></body></html>"`;

exports[`template snapshots > password-reset text 1`] = `
