{
  "name": "seta-agent-platform",
  "private": true,
  "scripts": {
    "prepare": "test -d .git && lefthook install || true",
    "build": "turbo run build",
    "dev": "turbo run dev",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "test:watch": "turbo run test:watch",
    "test:e2e": "pnpm --filter @seta/web test:e2e",
    "lint": "pnpm depcruise && pnpm lint:styles && pnpm lint:raw-sql && pnpm lint:test-layout && pnpm lint:module-shape && pnpm lint:boundaries && pnpm lint:rbac-coverage && pnpm exec biome ci .",
    "lint:boundaries": "eslint . --max-warnings=999",
    "lint:module-shape": "node scripts/lint-module-shape.mjs",
    "lint:rbac-coverage": "node scripts/lint-rbac-coverage.mjs",
    "lint:raw-sql": "bash scripts/audit-raw-sql.sh",
    "lint:styles": "bash packages/shared-config/scripts/grep-no-stray-styles.sh",
    "lint:test-layout": "node scripts/lint-test-layout.mjs",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "depcruise": "depcruise apps packages sdks --config .dependency-cruiser.cjs",
    "gen": "turbo gen run",
    "gen:rbac": "pnpm exec tsx scripts/gen-rbac.ts",
    "db:up": "docker compose -f infra/docker/compose.dev.yml up -d",
    "db:down": "docker compose -f infra/docker/compose.dev.yml down",
    "db:migrate": "pnpm -F @seta/cli exec tsx src/index.ts migrate",
    "db:seed": "pnpm -F @seta/cli exec tsx src/index.ts seed",
    "db:reset": "docker compose -f infra/docker/compose.dev.yml down -v && pnpm db:up && sleep 3 && pnpm db:migrate && pnpm db:seed",
    "demo:bootstrap": "bash scripts/demo-bootstrap.sh",
    "smoke:login": "tsx apps/web/e2e/login.smoke.ts",
    "docker:build:server": "docker build -f infra/docker/server.Dockerfile -t seta-server:local .",
    "docker:build:web": "docker build -f infra/docker/web.Dockerfile -t seta-web:local .",
    "docker:build": "pnpm docker:build:server && pnpm docker:build:web",
    "docs:hosting:check": "./scripts/check-env-doc-sync.sh",
    "docs:hosting:links": "for f in docs/hosting/*.md; do pnpm dlx markdown-link-check --quiet \"$f\" || exit 1; done",
    "release:check": "bash scripts/release-check.sh --no-build",
    "release:check:full": "bash scripts/release-check.sh"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "@seta/shared-config": "workspace:^",
    "@turbo/gen": "^2.9.18",
    "@types/eslint": "^9.6.1",
    "dependency-cruiser": "^17.4.3",
    "eslint": "^10.4.1",
    "eslint-plugin-boundaries": "^6.0.2",
    "jiti": "^2.7.0",
    "lefthook": "^2.1.9",
    "tsx": "^4.22.4",
    "turbo": "^2.9.18",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  },
  "packageManager": "pnpm@11.5.2+sha512.71c631e382066efc25625d5cf029075de07b61b37f6e27350fbd84b1bda5864c8c1967adc280776b45c30a715c0359a3be08fef42d5bb09e2b99029979692916",
  "engines": {
    "node": ">=24"
  }
}
