import { resolve } from 'node:path';
import { fileURLToPath } from 'node:url';
import type { ContributionRegistry } from '@seta/core';
import * as schema from './backend/db/schema.ts';
import { {{constantCase name}}_EVENTS } from './events.ts';
import { {{camelCase name}}Rbac } from './rbac.ts';

const __dirname = fileURLToPath(new URL('.', import.meta.url));

export function register{{pascalCase name}}Contributions(reg: ContributionRegistry): void {
  reg.module({
    name: '{{name}}',
    schema,
    migrationsDir: resolve(__dirname, '../drizzle/migrations'),
    events: {{constantCase name}}_EVENTS,
    rbac: {{camelCase name}}Rbac,
  });
}
